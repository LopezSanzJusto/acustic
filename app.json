{
  "expo": {
    "name": "acustic",
    "slug": "acustic",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "acustic",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "bundleIdentifier": "com.acustic.app",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "UIBackgroundModes": ["audio", "location", "fetch"]
      }
    },
    "android": {
      "package": "com.acustic.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.ACCESS_BACKGROUND_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "ios": { "useFrameworks": "static" }
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash.png",
          "resizeMode": "cover",
          "backgroundColor": "#7B5EA7",
          "imageWidth": 1284,
          "android": {
            "image": "./assets/images/splash.png",
            "resizeMode": "cover",
            "backgroundColor": "#7B5EA7",
            "imageWidth": 1284
          },
          "ios": {
            "image": "./assets/images/splash.png",
            "resizeMode": "cover",
            "backgroundColor": "#7B5EA7"
          }
        }
      ],
      "expo-font",
      "expo-image",
      "expo-web-browser",
      "expo-apple-authentication",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Esta app usa tu ubicación para guiarte por la ruta y avisarte cuando estás cerca de un punto de interés.",
          "isBackgroundLocationEnabled": true,
          "isIosBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/android-icon-monochrome.png",
          "color": "#7B5EA7",
          "sounds": []
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.230109414866-u533nltjkldq2f411vju5pu3qke0orna"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Usamos Face ID para iniciar sesión de forma rápida y segura."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ed2edee7-8731-4647-af8b-d3b988bb050f"
      }
    }
  }
}
