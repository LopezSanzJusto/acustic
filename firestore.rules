rules_version = '2';

// Reglas de Firestore para Acustic.
//
// Cambios respecto a la versión anterior:
//   - Se añade regla de `create` para /tours (necesaria para el panel de creador).
//   - Se añade regla de `delete` para /tours (necesaria para descartar drafts).
//   - Se generaliza la regla de subcollections para que:
//       a) Las reviews sigan funcionando (docId == uid).
//       b) Los points puedan crearse/borrarse con docId auto-generado,
//          validando propiedad por `creatorId` en el payload.
//
// Notas:
//   - `read: if true` en /tours y subcollections se mantiene para no romper
//     el warmup ni las pantallas de Explora (lectura pública de publicados,
//     reviews, etc.). Drafts quedan técnicamente expuestos a lectura
//     anónima, pero MVP — se endurecerá cuando todas las queries filtren
//     por `status: "published"`.
//   - `update` en /tours se deja amplio (cualquier auth) para que el
//     recálculo de rating/reviews que hace `reviewService` no se rompa.
//     Se endurecerá cuando ese cálculo migre a Cloud Function.

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Usuarios ─────────────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ─── Tours ────────────────────────────────────────────────────────
    match /tours/{tourId} {
      allow read: if true;

      // Crear sólo drafts propios.
      allow create: if request.auth != null
                    && request.resource.data.creatorId == request.auth.uid
                    && request.resource.data.status == 'draft';

      // Update amplio para no romper reviewService (recalcula rating).
      allow update: if request.auth != null;

      // Sólo el creador puede borrar su tour.
      allow delete: if request.auth != null
                    && resource.data.creatorId == request.auth.uid;

      // ─── Subcollections (points, reviews, …) ───────────────────────
      // Acepta tanto el modelo legacy (docId == uid, p.ej. reviews) como
      // el nuevo (docId auto-generado + creatorId en payload, p.ej. points).
      match /{subcollection}/{docId} {
        allow read: if true;

        allow create: if request.auth != null
                      && (
                        request.auth.uid == docId
                        || request.resource.data.creatorId == request.auth.uid
                      );

        allow update: if request.auth != null
                      && (
                        request.auth.uid == docId
                        || resource.data.creatorId == request.auth.uid
                      );

        allow delete: if request.auth != null
                      && (
                        request.auth.uid == docId
                        || resource.data.creatorId == request.auth.uid
                      );
      }
    }
  }
}
