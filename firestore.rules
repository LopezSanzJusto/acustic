rules_version = '2';

// Reglas de Firestore para Acustic.
//
// Modelo:
//   - /users/{uid}      : sólo el propio uid lee/escribe.
//   - /tours/{tourId}   : lectura pública (los drafts no salen en Explora
//                         porque el warmup filtra por status='published';
//                         para protegerlos hace falta endurecer queries
//                         del cliente, no las reglas). Write: sólo el
//                         creador puede crear drafts propios, actualizar
//                         (update es amplio para que reviewService pueda
//                         recalcular rating) y borrar lo suyo.
//   - /tours/{tourId}/points/{pointId} :
//                         lectura pública (idem). Write: sólo el creador
//                         del point (mismo uid).
//   - /tours/{tourId}/reviews/{reviewId} :
//                         lectura pública. Write: docId == auth.uid
//                         (modelo legacy donde el id de la review es el
//                         uid del autor).

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Usuarios ─────────────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ─── Tours ────────────────────────────────────────────────────────
    match /tours/{tourId} {
      allow read: if true;

      // Crear sólo drafts propios.
      allow create: if request.auth != null
                    && request.resource.data.creatorId == request.auth.uid
                    && request.resource.data.status == 'draft';

      // Update amplio para no romper reviewService (recalcula rating).
      allow update: if request.auth != null;

      // Sólo el creador puede borrar su tour.
      allow delete: if request.auth != null
                    && resource.data.creatorId == request.auth.uid;

      // ─── Subcollection: points ────────────────────────────────────
      match /points/{pointId} {
        allow read: if true;

        allow create: if request.auth != null
                      && request.resource.data.creatorId == request.auth.uid;

        allow update: if request.auth != null
                      && resource.data.creatorId == request.auth.uid;

        allow delete: if request.auth != null
                      && resource.data.creatorId == request.auth.uid;
      }

      // ─── Subcollection: reviews (modelo legacy docId == uid) ──────
      match /reviews/{reviewId} {
        allow read: if true;

        allow create, update, delete: if request.auth != null
                                      && request.auth.uid == reviewId;
      }
    }
  }
}
